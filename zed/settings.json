// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"cli_default_open_behavior": "existing_window",
 "lsp": {
  "vtsls": {
   "settings": {
    "typescript": {
     "updateImportsOnFileMove": {
      "enabled": "always"
     }
    },
    "javascript": {
     "updateImportsOnFileMove": {
      "enabled": "always"
     }
    }
   },
   "enable_lsp_tasks": true
  }
 },
 "outline_panel": {
  "dock": "left"
 },
 "collaboration_panel": {
  "dock": "left"
 },
 "base_keymap": "VSCode",
	"prettier": {
		"allowed": true,
		"useTabs": true,
	},
	"git_panel": {
		"dock": "left",
  "sort_by_path": false,
	},
	"show_edit_predictions": true,
	"tabs": {
		"git_status": true,
	},
	"tab_bar": {
		"show": true,
	},
	"hard_tabs": true,
	"tab_size": 4,
	"edit_predictions": {
		"provider": "ollama",
		"mode": "eager",
	},
	"agent": {
		"dock": "right",
  "inline_assistant_model": {
			"provider": "ollama",
			"model": "qwen2.5-coder:7b",
		},
		"default_model": {
			"provider": "ollama",
			"model": "qwen2.5-coder:7b",
		},
		"model_parameters": [],
	},
	"project_panel": {
		"dock": "left",
  "hide_hidden": false,
	},

	"hide_mouse": "on_typing",
	"cursor_blink": true,
	"buffer_font_weight": 400.0,
	"buffer_font_family": "CaskaydiaMono Nerd Font Mono",
	"icon_theme": "Base Charmed Icons",
	"ui_font_size": 16,
	"buffer_font_size": 14.0,
	"theme": "Catppuccin Macchiato (Blur)",
	"format_on_save": "on",
}
